    <script>
        const menuBtn = document.getElementById('menu-btn');
        const navLinks = document.getElementById('nav-links');
        const menuIcon = document.getElementById('menu-icon');

        function toggleMenu() {
            navLinks.classList.toggle('hidden');
            navLinks.classList.toggle('active');
            
            if (navLinks.classList.contains('hidden')) {
                menuIcon.classList.remove('fa-times');
                menuIcon.classList.add('fa-bars');
            } else {
                menuIcon.classList.remove('fa-bars');
                menuIcon.classList.add('fa-times');
            }
        }

        menuBtn.addEventListener('click', toggleMenu);

        function notifyFlexoraWA(event) {
            const fname = document.getElementById('fname').value;
            const lname = document.getElementById('lname').value;
            const mobile = document.getElementById('mobile').value;
            const service = document.getElementById('pService').value;
            const date = document.getElementById('pDate').value;
            const desc = document.getElementById('pDesc').value || "None";

            if (mobile.length !== 10 || isNaN(mobile)) { return; }

            if(fname && lname && mobile && service && date) {
                const fullName = fname.charAt(0).toUpperCase() + fname.slice(1).toLowerCase() + " " +
                                 lname.charAt(0).toUpperCase() + lname.slice(1).toLowerCase();

                const text = `Hello Dr. Divyansh,%0A%0AI want to book an appointment with you.%0A%0A*Patient Details:*%0A--------------------------%0A*Name:* ${fullName}%0A*Mobile:* ${mobile}%0A*Service:* ${service}%0A*Date:* ${date}%0A*Description:* ${desc}%0A--------------------------%0AThank you.`;

                const waURL = `https://wa.me/919369756224?text=${text}`;
                window.open(waURL, '_blank');
            }
        }
